{
  "manifest_version": 3,
  "name": "ZenGrowth: Focus Companion",
  "version": "1.0",
  "description": "Manages tab pressure and grows a digital bonsai based on your focus.",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open ZenGrowth"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}